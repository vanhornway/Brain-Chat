# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here  # never expose this to the browser

# AI provider API keys are entered by the user in the Settings panel
# and passed directly in the request body — they are NOT stored here.
